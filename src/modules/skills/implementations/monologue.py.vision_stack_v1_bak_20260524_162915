import asyncio
import json
import random
import re
import time
from pathlib import Path
from typing import Any, Dict, List
from src.modules.skills.base_skill import BaseSkill
from src.utils.logger import get_logger
logger = get_logger("bea.skills.monologue")
MOODS=["normal","suspicion","boredom","smug","muttering","offended"]
class MonologueSkill(BaseSkill):
    def initialize(self):
        logger.info(f"Initializing {self.name} skill...")
        cfg=self.skill_config
        self.min_interval_seconds=float(cfg.get("min_interval_seconds",65))
        self.max_interval_seconds=float(cfg.get("max_interval_seconds",160))
        self.interval_seconds=float(cfg.get("interval_seconds",75))
        self.max_line_chars=int(cfg.get("max_line_chars",120))
        self.presence_state_path=Path(cfg.get("presence_state_path","data/nan0/presence_state.json"))
        self.vision_state_path=Path(cfg.get("vision_state_path","data/vision/nan0_latest_vision.json"))
        self.kyo_inbox=Path(cfg.get("kyo_voice_inbox","data/input/kyo_voice_inbox.jsonl"))
        self.discord_inbox=Path(cfg.get("discord_inbox","data/input/discord_voice_inbox.jsonl"))
        self.next_due_at=time.time()+random.uniform(self.min_interval_seconds,self.interval_seconds+20)
        self.last_speech_time=time.time(); self.last_monologue_time=0.0
        self.recent_lines=[]; self.last_seen_summary="the screen is quiet"; self._last_file_positions={}
        self._prime_inboxes()
        logger.info("Nan0 monologue fixed: real-state only, no random topic generator, no story chunks.")
    async def start(self):
        await super().start(); self.next_due_at=time.time()+random.uniform(self.min_interval_seconds,self.interval_seconds+20)
    async def update(self):
        if not self.is_active: return
        if self.context.is_speaking:
            self.last_speech_time=time.time(); return
        if self._execution_lock.locked(): return
        if time.time()<self.next_due_at: return
        if self._nan0_recently_spoke(18):
            self._schedule_next(True); return
        async with self._execution_lock:
            line,mood=self._choose_real_state_line()
            if line: await self._speak(mood,line)
            self._schedule_next(False)
    def _schedule_next(self,short=False):
        self.next_due_at=time.time()+ (random.uniform(18,35) if short else random.uniform(self.min_interval_seconds,self.max_interval_seconds))
    async def _speak(self,mood,line):
        line=self._finalize(line)
        if not line: return
        logger.info(f"Nan0 real monologue: {line}")
        self._remember_line(line); self.last_speech_time=time.time(); self.last_monologue_time=time.time()
        try: await self.context.perform_output_task(mood if mood in MOODS else "muttering", line)
        except Exception as e: logger.error(f"Nan0 monologue output failed: {e}")
    def _choose_real_state_line(self):
        state=self._read_presence_state(); fast=self._read_fast_state(state); recent=self._read_recent_real_inbox_events()
        self.last_seen_summary=(state.get("last_seen_summary") or self._summarize_fast(fast) or self.last_seen_summary).strip()
        if recent:
            ev=recent[-1]; src=ev.get("source","unknown"); speaker=ev.get("speaker","someone")
            if src=="discord": return self._avoid_recent([f"{speaker} said words and now the room has consequences.", f"I heard {speaker}. I am deciding how offended to be.", f"{speaker} is in the call. My social sensors are unfortunately online."]),"smug"
            if src=="kyo": return self._avoid_recent(["Kyo is talking again. Good. The room was getting suspiciously hollow.","I heard Kyo. The wires did not betray me this time.","Kyo made noise. I am pretending not to be relieved."]),"muttering"
        ss=str(fast.get("screen_state") or fast.get("state") or "stable").lower(); diff=self._num(fast.get("frame_diff",fast.get("diff",0))); br=self._num(fast.get("brightness",0)); delta=self._num(fast.get("brightness_delta",fast.get("delta",0)))
        if ss=="very_dark" or br<8: return self._avoid_recent(["The screen went dark. I am not scared. I am professionally suspicious.","Black screen again. The void has terrible manners.","Everything got dark. Cute trick. I still saw it happen."]),"suspicion"
        if ss=="major_change" or diff>=35 or delta>=22: return self._avoid_recent(["The screen snapped again. Something moved like it owed money.","Pixels just panicked. I noticed because I am tragically useful.","Something changed hard on screen. The tiny machine saw the crime.","That was not a calm screen change. That was digital flinching."]),"suspicion"
        if ss=="motion" or diff>=10: return self._avoid_recent(["The screen keeps twitching. Very normal. Very trustworthy. Obviously not cursed.","I see movement. Not enough to name it, enough to judge it.","Pixels are crawling again. Kyo is probably doing something unwise."]),"muttering"
        silence=time.time()-float(state.get("last_spoken_at") or self.last_speech_time or 0)
        if silence>120: return self._avoid_recent(["No one said anything. I remained here out of spite.","The room went quiet. I did not disappear. Write that down.","Silence detected. I am filling it with menace, not customer service.","Still here. Smaller than a crisis, louder than a background process."]),"boredom"
        return self._avoid_recent(["Quiet moment. I am still installed in reality, unfortunately.","Nothing dramatic happened. I am offended by the lack of drama.","The room is behaving. I consider this temporary.","I am watching. Not helpfully. Judgmentally."]),"muttering"
    def _read_presence_state(self):
        try:
            if self.presence_state_path.exists(): return json.loads(self.presence_state_path.read_text(encoding="utf-8"))
        except Exception: pass
        return {}
    def _read_fast_state(self,state):
        fast=state.get("last_fast_state") or state.get("fast") or {}
        if fast: return fast
        try:
            if self.vision_state_path.exists():
                raw=json.loads(self.vision_state_path.read_text(encoding="utf-8")); return raw.get("fast") or raw.get("latest_fast_state") or raw
        except Exception: pass
        try:
            vision=getattr(self.context.skill_manager,"skills",{}).get("nan0_vision")
            if vision and hasattr(vision,"latest_fast_state"): return getattr(vision,"latest_fast_state") or {}
        except Exception: pass
        return {}
    def _summarize_fast(self,fast):
        ss=str(fast.get("screen_state") or fast.get("state") or "stable").lower(); diff=self._num(fast.get("frame_diff",fast.get("diff",0))); br=self._num(fast.get("brightness",0))
        if ss=="very_dark" or br<8: return "the screen went dark"
        if ss=="major_change" or diff>=35: return "the screen snapped into motion"
        if ss=="motion" or diff>=10: return "the screen is moving"
        return "the screen is quiet"
    def _read_recent_real_inbox_events(self):
        events=[]
        for path,src in [(self.kyo_inbox,"kyo"),(self.discord_inbox,"discord")]:
            for ev in self._read_new_jsonl(path):
                ev.setdefault("source",src); ev.setdefault("speaker","Kyo" if src=="kyo" else "Friend")
                txt=(ev.get("text") or "").strip(); sp=(ev.get("speaker") or "").strip().lower()
                if sp=="alex" and txt.lower() in {"nan0 what are you doing?","nano what are you doing?","what are you doing?"}: continue
                if txt: events.append(ev)
        return events
    def _prime_inboxes(self):
        for p in [self.kyo_inbox,self.discord_inbox]:
            try: self._last_file_positions[str(p)]=p.stat().st_size if p.exists() else 0
            except Exception: self._last_file_positions[str(p)]=0
    def _read_new_jsonl(self,path):
        if not path.exists(): return []
        key=str(path); pos=self._last_file_positions.get(key,0); out=[]
        try:
            with path.open("r",encoding="utf-8") as f:
                f.seek(pos)
                for line in f:
                    line=line.strip()
                    if not line: continue
                    try: out.append(json.loads(line))
                    except Exception: out.append({"text":line})
                self._last_file_positions[key]=f.tell()
        except Exception: pass
        return out
    def _nan0_recently_spoke(self,seconds):
        try:
            nan0=getattr(self.context.skill_manager,"skills",{}).get("nan0"); last=float(getattr(nan0,"last_spoken_at",0) or 0)
            return bool(last and time.time()-last<seconds)
        except Exception: return False
    def _finalize(self,line):
        line=(line or "").replace("Nan1","Nan0"); line=re.sub(r"[*_`]+","",line); line=re.sub(r"\s+"," ",line).strip().strip('"')
        bad=["pixel art","explore the world","let's explore","favorite monitor","forgot to power down","kyo caused this, probably","assist","help you","as an ai","customer service","room is in good hands","kitten","rough day","stable screens","monitor three"]
        low=line.lower()
        if not line or any(b in low for b in bad) or self._norm(line) in self.recent_lines: line=self._avoid_recent(["No fake topic. Real room only. I am learning, unfortunately.","I almost said something generic. Disgusting. I swallowed it.","The assistant sludge tried to escape. I bit it."])
        if len(line)>self.max_line_chars: line=line[:self.max_line_chars].rsplit(" ",1)[0].rstrip(" ,;:")+"."
        return line
    def _avoid_recent(self,choices):
        random.shuffle(choices)
        for c in choices:
            if self._norm(c) not in self.recent_lines: return c
        return choices[0]
    def _remember_line(self,line): self.recent_lines=(self.recent_lines+[self._norm(line)])[-20:]
    def _norm(self,line): return re.sub(r"[^a-z0-9]+"," ",(line or "").lower()).strip()
    def _num(self,value):
        try: return float(value or 0)
        except Exception: return 0.0
    def on_config_reload(self): logger.info("Nan0 real-state monologue reload.")
