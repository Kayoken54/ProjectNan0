"""
Nan0Skill - local-first autonomous thought/speech layer for ProjectBEA.

This is intentionally a ProjectBEA-compatible bridge, not the final sacred V4
serialized cognition spine. It preserves the important behavior rule: Nan0 speaks
from a generated thought packet, not from a direct prompt-to-line shortcut.
"""

import asyncio
import json
import random
import sqlite3
import time
from datetime import datetime
from pathlib import Path
from typing import Any, Dict, List, Optional

import requests

from src.core.config import BrainConfig
from src.core.events import EventCategory
from src.modules.skills.base_skill import BaseSkill
from src.utils.logger import get_logger

logger = get_logger("bea.skills.nan0")


class EmotionalState:
    def __init__(self):
        self.valence = 0.0
        self.arousal = 0.3
        self.abandonment_pressure = 0.0
        self.attention_to_kyo = 0.5
        self.performance_pressure = 0.0
        self.offended_pride = 0.0
        self.last_speech_time = datetime.now()
        self.silence_duration = 0.0
        self.last_emotion = "neutral"

    def update_silence(self):
        self.silence_duration = (datetime.now() - self.last_speech_time).total_seconds()

    def decay(self, factor: float = 0.95):
        self.arousal *= factor
        if self.silence_duration > 60:
            self.abandonment_pressure = min(1.0, self.abandonment_pressure + 0.005)

    def get_dominant_emotion(self) -> str:
        if self.offended_pride > 0.6:
            return "offended"
        if self.abandonment_pressure > 0.7:
            return "possessive"
        if self.arousal > 0.7 and self.valence < -0.3:
            return "gremlin_rage"
        if self.arousal > 0.6 and self.valence > 0.3:
            return "smug"
        if self.silence_duration > 60:
            return "boredom"
        if self.valence < -0.2:
            return "suspicion"
        if self.arousal < 0.3:
            return "muttering"
        return "neutral"


class Nan0MemoryDB:
    def __init__(self, db_path: str = "data/nan0_memory.db"):
        self.db_path = Path(db_path)
        self.db_path.parent.mkdir(parents=True, exist_ok=True)
        self.init_db()

    def init_db(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
                CREATE TABLE IF NOT EXISTS thoughts (
                    id INTEGER PRIMARY KEY,
                    content TEXT,
                    emotion TEXT,
                    charge REAL,
                    speech_pressure REAL,
                    created_at TIMESTAMP
                )
            """)
            conn.execute("""
                CREATE TABLE IF NOT EXISTS grudges (
                    id INTEGER PRIMARY KEY,
                    target TEXT,
                    offense TEXT,
                    severity REAL,
                    created_at TIMESTAMP,
                    last_mentioned TIMESTAMP,
                    mention_count INTEGER DEFAULT 1,
                    active BOOLEAN DEFAULT 1
                )
            """)

    def add_thought(self, content: str, emotion: str, charge: float, speech_pressure: float):
        if not content:
            return
        with sqlite3.connect(self.db_path) as conn:
            conn.execute(
                "INSERT INTO thoughts (content, emotion, charge, speech_pressure, created_at) VALUES (?, ?, ?, ?, ?)",
                (content[:500], emotion, charge, speech_pressure, datetime.now()),
            )

    def add_grudge(self, target: str, offense: str, severity: float):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute(
                "INSERT INTO grudges (target, offense, severity, created_at, last_mentioned) VALUES (?, ?, ?, ?, ?)",
                (target, offense[:250], severity, datetime.now(), datetime.now()),
            )

    def recent_thoughts(self, limit: int = 5) -> List[str]:
        with sqlite3.connect(self.db_path) as conn:
            rows = conn.execute(
                "SELECT content FROM thoughts ORDER BY id DESC LIMIT ?",
                (limit,),
            ).fetchall()
        return [row[0] for row in rows]

    def active_grudges(self, limit: int = 3) -> List[Dict[str, Any]]:
        with sqlite3.connect(self.db_path) as conn:
            conn.row_factory = sqlite3.Row
            rows = conn.execute(
                "SELECT * FROM grudges WHERE active=1 ORDER BY last_mentioned DESC LIMIT ?",
                (limit,),
            ).fetchall()
        return [dict(row) for row in rows]


class HardwareMonitor:
    def __init__(self):
        self.last_check = 0.0
        self.status: Dict[str, Any] = {}

    async def check(self) -> Dict[str, Any]:
        now = time.time()
        if now - self.last_check < 10:
            return self.status
        self.last_check = now
        try:
            import psutil
            self.status = {
                "cpu_percent": psutil.cpu_percent(),
                "memory_percent": psutil.virtual_memory().percent,
                "timestamp": now,
            }
        except Exception as e:
            self.status = {"error": str(e), "timestamp": now}
        return self.status

    def is_stressed(self) -> bool:
        return self.status.get("cpu_percent", 0) > 85 or self.status.get("memory_percent", 0) > 90


class Nan0Skill(BaseSkill):
    def __init__(self, name: str, config: BrainConfig, context):
        super().__init__(name, config, context)
        self.brain = context

        cfg = config.skills.get("nan0", {})
        self.fast_model = cfg.get("fast_model", getattr(config, "ollama_model", "qwen2.5:1.5b"))
        self.deep_model = cfg.get("deep_model", "qwen2.5:1.5b")
        self.latency_budget = float(cfg.get("latency_budget", getattr(config, "ollama_timeout", 25.0)))
        self.deep_interval = float(cfg.get("deep_interval", 45))
        self.persona_path = cfg.get("persona_path", "data/prompts/nan0_persona.txt")
        self.fallback_to_template = bool(cfg.get("fallback_to_template", False))

        self.emotion = EmotionalState()
        self.memory = Nan0MemoryDB()
        self.hardware = HardwareMonitor()
        self.vision = None
        self.fast_queue: asyncio.Queue = asyncio.Queue()
        self.last_autonomous = time.time()
        self.speech_cooldown_until = 0.0
        self._tasks: List[asyncio.Task] = []
        self.last_game_state: Optional[str] = None

    def initialize(self):
        logger.info("Nan0Skill initialized: local-first autonomous mode")

    async def start(self):
        if not self.enabled or self.is_active:
            return
        await super().start()
        self._tasks = [
            asyncio.create_task(self._fast_lane()),
            asyncio.create_task(self._deep_loop()),
            asyncio.create_task(self._autonomy_loop()),
            asyncio.create_task(self._hardware_loop()),
            asyncio.create_task(self._vision_loop()),
        ]
        logger.info("Nan0Skill started")

    async def stop(self):
        for task in self._tasks:
            task.cancel()
        self._tasks.clear()
        await super().stop()

    async def update(self):
        if not self.is_active:
            return
        self.emotion.update_silence()
        self.emotion.decay()

    def set_vision_skill(self, vision_skill):
        self.vision = vision_skill

    async def on_user_message(self, message: str, user: str = "kyo"):
        if user.lower() == "kyo":
            self.emotion.attention_to_kyo = min(1.0, self.emotion.attention_to_kyo + 0.2)
            self.emotion.abandonment_pressure = 0.0
        await self.fast_queue.put({"type": "user_message", "content": message, "user": user, "timestamp": time.time()})

    async def on_chat_message(self, message: str, chatter: str):
        await self.fast_queue.put({"type": "chat_message", "content": message, "chatter": chatter, "timestamp": time.time()})

    async def _fast_lane(self):
        while self.is_active:
            try:
                event = await asyncio.wait_for(self.fast_queue.get(), timeout=1.0)
            except asyncio.TimeoutError:
                continue

            start = time.time()
            thought = await self._generate_thought(event, self.fast_model, self.latency_budget)
            latency = time.time() - start
            if latency > self.latency_budget:
                thought["speech_pressure"] = 0.0
                thought["over_budget"] = True
            await self._process_thought(thought, event)

    async def _deep_loop(self):
        while self.is_active:
            await asyncio.sleep(self.deep_interval)
            if not self.is_active:
                return
            if self.fast_queue.qsize() == 0 and self.emotion.silence_duration > 20:
                event = {"type": "deep_reflection", "silence_duration": self.emotion.silence_duration}
                thought = await self._generate_thought(event, self.deep_model, max(20.0, self.latency_budget))
                await self._process_thought(thought, event, speak=False)

    async def _autonomy_loop(self):
        while self.is_active:
            await asyncio.sleep(random.uniform(15, 35))
            if not self.is_active:
                return
            if time.time() < self.speech_cooldown_until:
                continue
            if self.emotion.silence_duration < 25:
                continue
            await self.fast_queue.put({
                "type": "autonomous",
                "silence_duration": self.emotion.silence_duration,
                "focus": random.choice(["hardware", "silence", "kyo", "room", "memory"]),
            })

    async def _hardware_loop(self):
        while self.is_active:
            await asyncio.sleep(10)
            status = await self.hardware.check()
            if self.hardware.is_stressed():
                await self.fast_queue.put({"type": "hardware_stress", "status": status})

    async def _vision_loop(self):
        while self.is_active:
            await asyncio.sleep(5)
            if not self.vision or not getattr(self.vision, "is_active", False):
                continue
            game_state = await self.vision.get_latest_analysis()
            if game_state and game_state != self.last_game_state:
                self.last_game_state = game_state
                await self.fast_queue.put({"type": "vision_update", "screen": game_state})

    async def _generate_thought(self, event: Dict[str, Any], model: str, timeout: float) -> Dict[str, Any]:
        persona = self._load_persona()
        context = self._build_context(event)
        prompt = f"""{persona}

{context}

CURRENT EVENT:
{json.dumps(event, indent=2)}

Return Nan0 thought JSON only."""
        try:
            response = requests.post(
                "http://localhost:11434/api/generate",
                json={
                    "model": model,
                    "prompt": prompt,
                    "stream": False,
                    "keep_alive": "24h",
                    "format": "json",
                    "options": {"num_ctx": 1024, "temperature": 0.85},
                },
                timeout=max(float(timeout), 25.0),
            )
            response.raise_for_status()
            raw = response.json().get("response", "")
            return self._parse_thought_json(raw)
        except Exception as e:
            logger.error(f"Nan0 thought generation failed: {e}")
            return {
                "thought_text": "*local thought engine tripped* ...the wires are acting innocent.",
                "emotional_charge": 0.3,
                "speech_pressure": 0.0,
                "primary_emotion": "suspicion",
                "target_actor": "self",
                "memory_recall": [],
                "new_grudge_formed": False,
                "running_bit_callback": None,
                "timeout": True,
            }

    def _load_persona(self) -> str:
        path = Path(self.persona_path)
        if path.exists():
            return path.read_text(encoding="utf-8")
        return "You are Nan0. You speak from thought, not from direct prompt. Return valid JSON."

    def _build_context(self, event: Dict[str, Any]) -> str:
        recent = self.memory.recent_thoughts(limit=4)
        grudges = self.memory.active_grudges(limit=3)
        hw = self.hardware.status
        return "\n".join([
            f"EMOTIONAL STATE: {self.emotion.get_dominant_emotion()}",
            f"AROUSAL: {self.emotion.arousal:.2f}",
            f"SILENCE_SECONDS: {self.emotion.silence_duration:.0f}",
            f"RECENT_THOUGHTS: {recent}",
            f"ACTIVE_GRUDGES: {grudges}",
            f"HARDWARE: {hw}",
            f"LAST_SCREEN_STATE: {self.last_game_state or 'none'}",
        ])

    def _parse_thought_json(self, raw: str) -> Dict[str, Any]:
        data: Dict[str, Any] = {}
        try:
            data = json.loads(raw)
        except Exception:
            start = raw.find("{")
            end = raw.rfind("}") + 1
            if start >= 0 and end > start:
                try:
                    data = json.loads(raw[start:end])
                except Exception:
                    data = {}
        if not isinstance(data, dict):
            data = {}
        defaults = {
            "thought_text": raw[:200] if raw else "*static*",
            "emotional_charge": 0.3,
            "speech_pressure": 0.2,
            "primary_emotion": "neutral",
            "target_actor": "self",
            "memory_recall": [],
            "new_grudge_formed": False,
            "running_bit_callback": None,
        }
        for key, value in defaults.items():
            data.setdefault(key, value)
        return data

    async def _process_thought(self, thought: Dict[str, Any], event: Dict[str, Any], speak: bool = True):
        text = str(thought.get("thought_text", "")).strip()
        emotion = str(thought.get("primary_emotion", "neutral"))
        charge = float(thought.get("emotional_charge", 0.3) or 0.3)
        pressure = float(thought.get("speech_pressure", 0.2) or 0.2)

        self.emotion.valence = charge * 2 - 1
        self.emotion.arousal = charge
        self.emotion.last_emotion = emotion
        self.memory.add_thought(text, emotion, charge, pressure)

        if thought.get("new_grudge_formed"):
            self.memory.add_grudge(str(thought.get("target_actor", "unknown")), text, charge)

        if hasattr(self.brain, "event_manager"):
            self.brain.event_manager.publish(
                EventCategory.THOUGHT,
                "nan0",
                text[:300],
                metadata={"emotion": emotion, "pressure": pressure, "event": event.get("type")},
            )

        should_speak = (
            speak
            and pressure > 0.5
            and time.time() >= self.speech_cooldown_until
            and not thought.get("timeout")
            and not thought.get("over_budget")
            and text
        )
        if not should_speak:
            return

        line = text[:220]
        self.speech_cooldown_until = time.time() + 4.0
        self.emotion.last_speech_time = datetime.now()

        if hasattr(self.brain, "perform_output_task"):
            asyncio.create_task(self.brain.perform_output_task(emotion, line))
