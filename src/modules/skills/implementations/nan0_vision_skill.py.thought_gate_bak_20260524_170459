"""
Nan0 Vision Stack V1.
Layer 1: fast OpenCV/PIL reflex vision.
Layer 2: lightweight semantic classification.
Layer 3: Nan0 interpretation layer.
Optional OCR and YOLO are supported but off by default.
"""
import asyncio
import json
import re
import time
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

import mss
from PIL import Image, ImageChops, ImageStat

from src.modules.skills.base_skill import BaseSkill
from src.utils.logger import get_logger

logger = get_logger("bea.skills.nan0vision")

try:
    import cv2  # type: ignore
    import numpy as np  # type: ignore
except Exception:
    cv2 = None
    np = None


class OptionalLearners:
    def __init__(self, cfg: Dict[str, Any]):
        self.cfg = cfg
        self.ocr_enabled = bool(cfg.get("ocr_enabled", False))
        self.yolo_enabled = bool(cfg.get("yolo_enabled", False))
        self.ocr_backend = cfg.get("ocr_backend", "auto")
        self.yolo_model_name = cfg.get("yolo_model", "yolov8n.pt")
        self.paddle_ocr = None
        self.tesseract = None
        self.yolo = None
        self._ocr_checked = False
        self._yolo_checked = False

    def _init_ocr(self):
        if self._ocr_checked or not self.ocr_enabled:
            return
        self._ocr_checked = True
        if self.ocr_backend in ("auto", "paddle"):
            try:
                from paddleocr import PaddleOCR  # type: ignore
                self.paddle_ocr = PaddleOCR(use_angle_cls=False, lang="en", show_log=False)
                logger.info("VisionStack V1: PaddleOCR enabled.")
                return
            except Exception as e:
                logger.info(f"VisionStack V1: PaddleOCR unavailable: {e}")
        if self.ocr_backend in ("auto", "tesseract"):
            try:
                import pytesseract  # type: ignore
                self.tesseract = pytesseract
                logger.info("VisionStack V1: pytesseract enabled.")
            except Exception as e:
                logger.info(f"VisionStack V1: pytesseract unavailable: {e}")

    def _init_yolo(self):
        if self._yolo_checked or not self.yolo_enabled:
            return
        self._yolo_checked = True
        try:
            from ultralytics import YOLO  # type: ignore
            self.yolo = YOLO(self.yolo_model_name)
            logger.info(f"VisionStack V1: YOLO enabled: {self.yolo_model_name}")
        except Exception as e:
            logger.info(f"VisionStack V1: YOLO unavailable: {e}")
            self.yolo = None

    def ocr(self, image: Image.Image) -> Dict[str, Any]:
        if not self.ocr_enabled:
            return {"backend": "disabled", "text": "", "words": []}
        self._init_ocr()
        try:
            small = image.copy()
            small.thumbnail((960, 540))
            if self.paddle_ocr is not None and np is not None:
                result = self.paddle_ocr.ocr(np.array(small.convert("RGB")), cls=False)
                words: List[str] = []
                for block in result or []:
                    for item in block or []:
                        try:
                            words.append(str(item[1][0]))
                        except Exception:
                            pass
                return {"backend": "paddle", "text": " ".join(words)[:2000], "words": words[:80]}
            if self.tesseract is not None:
                text = self.tesseract.image_to_string(small) or ""
                words = re.findall(r"[A-Za-z0-9_#@:/.-]{2,}", text)
                return {"backend": "tesseract", "text": text[:2000], "words": words[:80]}
        except Exception as e:
            return {"backend": "error", "text": "", "words": [], "error": str(e)[:200]}
        return {"backend": "unavailable", "text": "", "words": []}

    def detect(self, image: Image.Image) -> Dict[str, Any]:
        if not self.yolo_enabled:
            return {"backend": "disabled", "objects": []}
        self._init_yolo()
        if self.yolo is None or np is None:
            return {"backend": "unavailable", "objects": []}
        try:
            small = image.copy()
            small.thumbnail((640, 360))
            arr = np.array(small.convert("RGB"))
            results = self.yolo.predict(arr, verbose=False, imgsz=640, conf=float(self.cfg.get("yolo_conf", 0.35)))
            objects = []
            for r in results:
                names = getattr(r, "names", {})
                boxes = getattr(r, "boxes", None)
                if boxes is None:
                    continue
                for box in boxes:
                    cls_id = int(box.cls[0])
                    objects.append({"label": str(names.get(cls_id, cls_id)), "conf": round(float(box.conf[0]), 3)})
            return {"backend": "yolo", "objects": objects[:40]}
        except Exception as e:
            return {"backend": "error", "objects": [], "error": str(e)[:200]}


class Nan0VisionSkill(BaseSkill):
    def __init__(self, name, config, brain):
        super().__init__(name, config, brain)
        cfg = self.skill_config
        self.monitor_index = int(cfg.get("monitor", cfg.get("monitor_index", 3)))
        self.fast_interval = float(cfg.get("fast_interval", 0.5))
        self.reflex_width = int(cfg.get("reflex_width", 480))
        self.reflex_height = int(cfg.get("reflex_height", 270))
        self.motion_threshold = float(cfg.get("motion_threshold", 10.0))
        self.major_change_threshold = float(cfg.get("major_change_threshold", 26.0))
        self.dark_threshold = float(cfg.get("dark_threshold", 28.0))
        self.ocr_interval = float(cfg.get("ocr_interval", 5.0))
        self.yolo_interval = float(cfg.get("yolo_interval", 3.0))
        self.semantic_interval = float(cfg.get("semantic_interval", 15.0))
        self.log_interval = float(cfg.get("fast_log_interval", 8.0))
        self.output_path = Path(cfg.get("output_path", "data/vision/nan0_latest_vision.json"))
        self.stack_output_path = Path(cfg.get("stack_output_path", "data/vision/nan0_vision_stack_state.json"))
        self.event_path = Path(cfg.get("event_path", "data/vision/nan0_vision_events.jsonl"))
        for p in (self.output_path, self.stack_output_path, self.event_path):
            p.parent.mkdir(parents=True, exist_ok=True)
        self.optional = OptionalLearners(cfg)
        self.running = False
        self.task: Optional[asyncio.Task] = None
        self.prev_gray = None
        self.prev_brightness: Optional[float] = None
        self.prev_screen_state: Optional[str] = None
        self.last_ocr_at = 0.0
        self.last_yolo_at = 0.0
        self.last_semantic_at = 0.0
        self.last_log_at = 0.0
        self.last_event_key = ""
        self.latest_ocr = {"backend": "disabled", "text": "", "words": []}
        self.latest_yolo = {"backend": "disabled", "objects": []}
        self.latest_semantic: Dict[str, Any] = {}
        self.latest_state: Dict[str, Any] = {}

    def initialize(self):
        try:
            with mss.mss() as sct:
                logger.info("Nan0VisionStack V1: detected monitors from mss:")
                for i, monitor in enumerate(sct.monitors):
                    logger.info(f"Monitor {i}: {monitor}")
            if self.monitor_index == 0:
                logger.warning("VisionStack V1: monitor 0 is full desktop. Forcing monitor 3.")
                self.monitor_index = 3
        except Exception as e:
            logger.error(f"VisionStack V1 monitor init failed: {e}")
        logger.info(
            f"Nan0VisionStack V1 active: Layer1 {self.fast_interval:.2f}s, OCR={self.optional.ocr_enabled}, YOLO={self.optional.yolo_enabled}, monitor={self.monitor_index}"
        )

    async def start(self):
        if self.running:
            return
        self.running = True
        self.is_active = True
        self.task = asyncio.create_task(self._loop())
        logger.info("Nan0VisionStack V1 started.")

    async def stop(self):
        self.running = False
        if self.task:
            self.task.cancel()
            try:
                await self.task
            except asyncio.CancelledError:
                pass
        self.is_active = False
        logger.info("Nan0VisionStack V1 stopped.")

    async def update(self):
        return

    async def _loop(self):
        while self.running:
            start = time.time()
            try:
                img = self._capture()
                if img is not None:
                    state = self._state(img)
                    self.latest_state = state
                    self._write(state)
                    self._log(state)
            except Exception as e:
                logger.error(f"VisionStack V1 loop error: {e}")
            await asyncio.sleep(max(0.02, self.fast_interval - (time.time() - start)))

    def _capture(self) -> Optional[Image.Image]:
        try:
            with mss.mss() as sct:
                if self.monitor_index >= len(sct.monitors):
                    logger.error(f"VisionStack V1: monitor {self.monitor_index} unavailable.")
                    return None
                shot = sct.grab(sct.monitors[self.monitor_index])
                return Image.frombytes("RGB", shot.size, shot.rgb)
        except Exception as e:
            logger.error(f"VisionStack V1 capture error: {e}")
            return None

    def _state(self, img: Image.Image) -> Dict[str, Any]:
        now = time.time()
        l1 = self._layer1(img, now)
        if now - self.last_ocr_at >= self.ocr_interval:
            self.last_ocr_at = now
            self.latest_ocr = self.optional.ocr(img)
        if now - self.last_yolo_at >= self.yolo_interval:
            self.last_yolo_at = now
            self.latest_yolo = self.optional.detect(img)
        l1.update(self._derive(l1, self.latest_ocr, self.latest_yolo))
        if now - self.last_semantic_at >= self.semantic_interval or l1.get("major_change"):
            self.last_semantic_at = now
            self.latest_semantic = self._layer2(l1, self.latest_ocr, self.latest_yolo)
        l3 = self._layer3(l1, self.latest_semantic)
        return {
            "timestamp": now,
            "monitor": self.monitor_index,
            "layer1_reflex": l1,
            "layer2_semantic": self.latest_semantic,
            "layer3_nan0_interpretation": l3,
            "latest_ocr": self.latest_ocr,
            "latest_yolo": self.latest_yolo,
            "screen_state": l1.get("screen_state"),
            "frame_diff": l1.get("frame_diff"),
            "brightness": l1.get("brightness"),
            "brightness_delta": l1.get("brightness_delta"),
            "moving": l1.get("motion_intensity", 0) > 0.15,
            "major_change": l1.get("major_change", False),
            "summary": l3.get("thought_seed", ""),
            "thought_seed": l3.get("thought_seed", ""),
            "thoughtworthy": l3.get("thoughtworthy", False),
        }

    def _layer1(self, img: Image.Image, now: float) -> Dict[str, Any]:
        small = img.copy()
        small.thumbnail((self.reflex_width, self.reflex_height))
        gray = small.convert("L")
        brightness = float(ImageStat.Stat(gray).mean[0])
        frame_diff = 0.0
        if self.prev_gray is not None:
            if cv2 is not None and np is not None:
                arr = np.array(gray)
                if arr.shape == self.prev_gray.shape:
                    frame_diff = float(cv2.absdiff(arr, self.prev_gray).mean())
                self.prev_gray = arr
            else:
                diff = ImageChops.difference(gray, self.prev_gray)
                frame_diff = float(ImageStat.Stat(diff).mean[0])
                self.prev_gray = gray
        else:
            self.prev_gray = np.array(gray) if cv2 is not None and np is not None else gray
        brightness_delta = abs(brightness - self.prev_brightness) if self.prev_brightness is not None else 0.0
        self.prev_brightness = brightness
        edge_density, text_density, ui_density = self._features(gray)
        motion = max(0.0, min(1.0, frame_diff / 60.0))
        dark = brightness < self.dark_threshold
        major = frame_diff >= self.major_change_threshold or brightness_delta >= 28.0
        if dark:
            screen_state = "very_dark"
        elif major:
            screen_state = "major_change"
        elif frame_diff >= self.motion_threshold:
            screen_state = "motion"
        else:
            screen_state = "stable"
        changed = self.prev_screen_state is not None and screen_state != self.prev_screen_state
        self.prev_screen_state = screen_state
        menu_open = (text_density > 0.18 and motion < 0.25) or ui_density > 0.10
        combat = motion > 0.42 and not menu_open and not dark
        return {
            "timestamp": now,
            "screen_state": screen_state,
            "state_changed": changed,
            "frame_diff": round(frame_diff, 3),
            "brightness": round(brightness, 3),
            "brightness_delta": round(brightness_delta, 3),
            "motion_intensity": round(motion, 3),
            "dark_scene": dark,
            "major_change": major,
            "edge_density": round(edge_density, 4),
            "text_density": round(text_density, 4),
            "ui_rect_density": round(ui_density, 4),
            "menu_open": bool(menu_open),
            "combat": bool(combat),
            "inventory_visible": False,
            "discord_visible": False,
            "game_ui_detected": "unknown",
        }

    def _features(self, gray: Image.Image) -> Tuple[float, float, float]:
        if cv2 is None or np is None:
            return 0.0, 0.0, 0.0
        try:
            arr = np.array(gray)
            edges = cv2.Canny(arr, 80, 160)
            edge_density = float((edges > 0).mean())
            sx = cv2.Sobel(arr, cv2.CV_64F, 1, 0, ksize=3)
            sy = cv2.Sobel(arr, cv2.CV_64F, 0, 1, ksize=3)
            grad = np.sqrt(sx * sx + sy * sy)
            text_density = float((grad > 55).mean())
            contours, _ = cv2.findContours(edges, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
            total = arr.shape[0] * arr.shape[1]
            rect_area = 0.0
            for c in contours[:200]:
                x, y, w, h = cv2.boundingRect(c)
                area = w * h
                if 300 < area < total * 0.5 and w > 20 and h > 8:
                    aspect = w / max(1, h)
                    if 1.2 < aspect < 20:
                        rect_area += area
            return edge_density, text_density, min(1.0, rect_area / max(1, total))
        except Exception:
            return 0.0, 0.0, 0.0

    def _derive(self, l1: Dict[str, Any], ocr: Dict[str, Any], yolo: Dict[str, Any]) -> Dict[str, Any]:
        text = (ocr.get("text") or "").lower()
        objects = [str(o.get("label", "")).lower() for o in yolo.get("objects", [])]
        inventory_words = ("inventory", "items", "equipment", "loadout", "perks", "settings", "options", "map", "quest")
        discord_words = ("discord", "voice connected", "general", "channel", "mute", "deafen")
        dbd_words = ("dead by daylight", "bloodpoints", "survivor", "killer", "generator", "trial", "ready")
        code_words = ("python", "traceback", "powershell", "error", "exception", "config.json")
        browser_words = ("http", "www", "search", "youtube", "google", "reddit")
        game = "unknown"
        if any(w in text for w in dbd_words):
            game = "dead_by_daylight"
        elif any(w in text for w in code_words):
            game = "coding"
        elif any(w in text for w in browser_words):
            game = "browser"
        elif l1.get("motion_intensity", 0) > 0.25:
            game = "unknown_gameplay"
        return {
            "inventory_visible": any(w in text for w in inventory_words),
            "discord_visible": any(w in text for w in discord_words),
            "game_ui_detected": game,
            "object_hints": objects[:12],
            "ocr_keywords": self._keywords(text),
        }

    def _keywords(self, text: str) -> List[str]:
        words = re.findall(r"[a-zA-Z0-9_]{3,}", text.lower())
        boring = {"the", "and", "for", "you", "are", "with", "that", "this", "from", "have", "not"}
        out: List[str] = []
        for w in words:
            if w not in boring and w not in out:
                out.append(w)
            if len(out) >= 20:
                break
        return out

    def _layer2(self, l1: Dict[str, Any], ocr: Dict[str, Any], yolo: Dict[str, Any]) -> Dict[str, Any]:
        activity, tone, likely, attention = "quiet screen", "neutral", "unknown", "screen state"
        if l1.get("dark_scene"):
            activity, tone, attention = "dark scene or loading transition", "tense", "darkness / transition"
        elif l1.get("combat"):
            activity, tone, likely, attention = "high motion gameplay", "stressful", "active play or fight", "movement spike"
        elif l1.get("menu_open") or l1.get("inventory_visible"):
            activity, tone, likely, attention = "menu or loadout screen", "planning", "checking options", "UI/menu"
        elif l1.get("major_change"):
            activity, tone, attention = "scene transition", "alert", "sudden visual change"
        elif l1.get("motion_intensity", 0) > 0.16:
            activity, tone, likely, attention = "light gameplay motion", "active", "moving around", "motion"
        if l1.get("game_ui_detected") == "dead_by_daylight":
            activity, tone, attention = "possible DBD lobby/action", "suspicious", "horror UI"
        conf = 0.35 + (0.25 if ocr.get("words") else 0) + (0.2 if yolo.get("objects") else 0) + (0.1 if l1.get("major_change") else 0)
        return {"activity": activity, "tone": tone, "likely_player_state": likely, "social_context": "discord_visible" if l1.get("discord_visible") else "unknown", "attention_target": attention, "confidence": round(min(0.95, conf), 2), "backend": "heuristic_v1"}

    def _layer3(self, l1: Dict[str, Any], l2: Dict[str, Any]) -> Dict[str, Any]:
        thoughtworthy, stakes, perceived, mood, seed = False, "low", "boring screen behavior", "muttering", ""
        if l1.get("dark_scene") and l1.get("brightness_delta", 0) > 20:
            thoughtworthy, stakes, perceived, mood, seed = True, "suspicious", "screen dropped into black", "suspicion", "Everything just fell into black. Hate that little trick."
        elif l1.get("combat"):
            thoughtworthy, stakes, perceived, mood, seed = True, "high", "combat-shaped pixel panic", "gremlin_rage", "The screen is thrashing. Kyo is either fighting something or feeding the disaster engine."
        elif l1.get("menu_open") or l1.get("inventory_visible"):
            thoughtworthy, stakes, perceived, mood, seed = True, "medium", "Kyo is trapped in menus", "smug", "Menus. Again. Kyo is negotiating with rectangles like that ever helped anyone."
        elif l1.get("major_change"):
            thoughtworthy, stakes, perceived, mood, seed = True, "medium", "visual jump / scene change", "suspicion", "The screen snapped. Something changed too fast to be innocent."
        elif l1.get("motion_intensity", 0) > 0.25:
            thoughtworthy, stakes, perceived, mood, seed = True, "medium_low", "active movement", "muttering", "Pixels are moving hard. I am judging the physics and Kyo's choices."
        elif l1.get("game_ui_detected") == "coding":
            thoughtworthy, stakes, perceived, mood, seed = True, "medium", "code/debug territory", "offended", "Code is on screen. The error gremlins are probably chewing wires again."
        return {"perceived_threat": perceived, "emotional_stakes": stakes, "ego_position": "superior_tiny_machine_observer", "mood": mood, "thought_seed": seed, "thoughtworthy": thoughtworthy, "speak_reason": "real_visual_change" if thoughtworthy else "none", "do_not_speak_if_only_silence": True}

    def _write(self, state: Dict[str, Any]):
        try:
            text = json.dumps(state, indent=2, ensure_ascii=False)
            self.stack_output_path.write_text(text, encoding="utf-8")
            self.output_path.write_text(text, encoding="utf-8")
            key = f"{state.get('screen_state')}:{state.get('thought_seed')}"
            if state.get("thoughtworthy") and key != self.last_event_key:
                self.last_event_key = key
                with self.event_path.open("a", encoding="utf-8") as f:
                    f.write(json.dumps({"time": time.time(), "event": state.get("screen_state"), "thought_seed": state.get("thought_seed"), "semantic": state.get("layer2_semantic", {})}, ensure_ascii=False) + "\n")
        except Exception as e:
            logger.error(f"VisionStack V1 write error: {e}")

    def _log(self, state: Dict[str, Any]):
        now = time.time()
        l1 = state.get("layer1_reflex", {})
        l3 = state.get("layer3_nan0_interpretation", {})
        if not l3.get("thoughtworthy") and now - self.last_log_at < self.log_interval:
            return
        self.last_log_at = now
        logger.info("VisionStack V1: %s motion=%.2f text=%.2f menu=%s combat=%s game=%s thought=%s" % (l1.get("screen_state"), float(l1.get("motion_intensity", 0)), float(l1.get("text_density", 0)), l1.get("menu_open"), l1.get("combat"), l1.get("game_ui_detected"), l3.get("thought_seed") or "none"))
