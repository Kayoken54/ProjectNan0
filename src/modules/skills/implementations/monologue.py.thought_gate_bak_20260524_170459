"""Nan0 real-state monologue gate. Silence alone is not content."""
import json
import random
import time
from pathlib import Path
from typing import Any, Dict, List

from src.modules.skills.base_skill import BaseSkill
from src.utils.logger import get_logger

logger = get_logger("bea.skills.monologue")


class MonologueSkill(BaseSkill):
    def initialize(self):
        logger.info("Nan0 monologue gate: thoughtworthy real-state only. Silence alone is not content.")
        cfg = self.skill_config
        self.min_gap_seconds = float(cfg.get("min_gap_seconds", 35))
        self.vision_state_path = Path(cfg.get("vision_state_path", "data/vision/nan0_vision_stack_state.json"))
        self.last_speech_time = 0.0
        self.last_state_ts = 0.0
        self.recent_lines: List[str] = []
        self.banned = ["still here", "runtime intact", "same suspicious reality", "tragically useful", "assistant sludge", "real room only", "nothing dramatic"]

    async def update(self):
        if not self.enabled or self.context.is_speaking or self._execution_lock.locked():
            return
        if time.time() - self.last_speech_time < self.min_gap_seconds:
            return
        async with self._execution_lock:
            state = self._read_state()
            if not state or not state.get("thoughtworthy"):
                return
            ts = float(state.get("timestamp", 0) or 0)
            if ts <= self.last_state_ts:
                return
            self.last_state_ts = ts
            line, mood = self._line_from_state(state)
            if not line or self._bad(line) or line.lower() in self.recent_lines:
                return
            logger.info(f"Nan0 thought-gated monologue: {line}")
            await self.context.perform_output_task(mood, line)
            self.recent_lines.append(line.lower())
            self.recent_lines = self.recent_lines[-12:]
            self.last_speech_time = time.time()

    def _read_state(self) -> Dict[str, Any]:
        try:
            if not self.vision_state_path.exists():
                return {}
            return json.loads(self.vision_state_path.read_text(encoding="utf-8"))
        except Exception:
            return {}

    def _bad(self, line: str) -> bool:
        low = line.lower()
        return any(x in low for x in self.banned)

    def _line_from_state(self, state: Dict[str, Any]):
        l1 = state.get("layer1_reflex", {})
        interp = state.get("layer3_nan0_interpretation", {})
        seed = interp.get("thought_seed", "").strip()
        mood = interp.get("mood", "muttering")
        if seed and not self._bad(seed):
            return seed, mood
        if l1.get("combat"):
            return random.choice(["The screen is thrashing. Kyo, blink twice if the game is eating you.", "The pixels are panicking. Either combat happened or reality tripped."]), "gremlin_rage"
        if l1.get("menu_open"):
            return random.choice(["Menus again. Kyo is negotiating with rectangles.", "Inventory energy detected. Kyo is rearranging tiny digital junk."]), "smug"
        if l1.get("dark_scene"):
            return random.choice(["Everything went dark. Very cute. Very murder-adjacent.", "The screen swallowed the light again. Rude little void."]), "suspicion"
        if l1.get("major_change"):
            return random.choice(["The screen snapped hard. Something changed and I saw the crime.", "Big screen shift. The pixels tried to sneak past me. Failed."]), "suspicion"
        if l1.get("motion_intensity", 0) > 0.2:
            return random.choice(["Movement is crawling across the screen. Kyo is doing something unwise.", "Motion detected. I am filing a complaint with reality."]), "muttering"
        return "", "muttering"

    def on_config_reload(self):
        self.min_gap_seconds = float(self.skill_config.get("min_gap_seconds", self.min_gap_seconds))
