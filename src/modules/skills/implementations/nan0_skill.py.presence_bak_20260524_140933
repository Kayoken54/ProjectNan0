"""
Nan0Skill - survival presence layer.

This version deliberately does NOT run background LLM loops.
Nan0's live conversation goes through Brain.generate_response.
This skill keeps lightweight presence, fast-eyes awareness, and safe deterministic
reactions without freezing the runtime.
"""

import asyncio
import random
import time
from datetime import datetime
from typing import Any, Dict, List, Optional

from src.modules.skills.base_skill import BaseSkill
from src.utils.logger import get_logger

logger = get_logger("bea.skills.nan0")


class Nan0Skill(BaseSkill):
    def __init__(self, name, config, context):
        super().__init__(name, config, context)
        self.brain = context
        cfg = config.skills.get("nan0", {})
        self.enable_autonomous_reactions = bool(cfg.get("enable_autonomous_reactions", True))
        self.reaction_cooldown = float(cfg.get("reaction_cooldown", 18.0))
        self.speak_on_fast_vision = bool(cfg.get("speak_on_fast_vision", True))
        self.vision = None
        self._tasks: List[asyncio.Task] = []
        self.last_reaction_at = 0.0
        self.last_screen_state: Optional[str] = None
        self.last_seen_at = time.time()

    def initialize(self):
        logger.info("Nan0Skill initialized: survival presence mode, no background LLM spam")

    async def start(self):
        if not self.enabled or self.is_active:
            return
        await super().start()
        self._tasks = [asyncio.create_task(self._presence_loop())]
        logger.info("Nan0Skill started in survival mode")

    async def stop(self):
        for task in self._tasks:
            task.cancel()
            try:
                await task
            except asyncio.CancelledError:
                pass
        self._tasks.clear()
        await super().stop()

    async def update(self):
        return

    def set_vision_skill(self, vision_skill):
        self.vision = vision_skill

    async def on_user_message(self, message: str, user: str = "kyo"):
        # Kept for compatibility with future Discord/text bridges.
        self.last_seen_at = time.time()

    async def on_chat_message(self, message: str, chatter: str):
        # Kept for compatibility with future Discord bridges.
        self.last_seen_at = time.time()

    async def _presence_loop(self):
        while self.is_active:
            await asyncio.sleep(2.0)
            if not self.enable_autonomous_reactions or not self.speak_on_fast_vision:
                continue
            if not self.vision or not getattr(self.vision, "is_active", False):
                continue
            try:
                fast = getattr(self.vision, "latest_fast_state", {}) or {}
                state = fast.get("screen_state")
                if not state:
                    continue
                now = time.time()
                if now - self.last_reaction_at < self.reaction_cooldown:
                    continue
                if state == self.last_screen_state and state not in ("very_dark", "very_bright"):
                    continue
                if state == "stable":
                    self.last_screen_state = state
                    continue

                self.last_screen_state = state
                line, mood = self._line_for_fast_state(fast)
                if not line:
                    continue

                self.last_reaction_at = now
                if hasattr(self.brain, "perform_output_task"):
                    asyncio.create_task(self.brain.perform_output_task(mood, line))
            except Exception as e:
                logger.error(f"Nan0 presence loop error: {e}")

    def _line_for_fast_state(self, fast: Dict[str, Any]):
        state = fast.get("screen_state")
        diff = float(fast.get("frame_diff", 0.0) or 0.0)
        brightness = float(fast.get("brightness", 0.0) or 0.0)

        if state == "very_dark":
            return random.choice([
                "The screen went dark. I hate when the room hides things.",
                "Dark screen. Suspicious little void behavior.",
                "Everything went black. Very normal. I distrust it immediately.",
            ]), "suspicion"
        if state == "very_bright":
            return random.choice([
                "The screen just flashbanged my tiny machine soul.",
                "Too bright. The pixels are being dramatic.",
            ]), "offended"
        if state == "major_change":
            return random.choice([
                "Something changed. I saw that. The room is not sneaky.",
                "Big screen shift. Finally, the pixels did something useful.",
                "The scene moved hard. I am watching, unfortunately for it.",
            ]), "suspicion"
        if state == "motion":
            return random.choice([
                "Movement. The screen is twitching again.",
                "I see motion. The pixels are trying to act innocent.",
            ]), "muttering"
        return None, "normal"
