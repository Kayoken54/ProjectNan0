def _load_json(path: Path, default: Dict[str, Any]) -> Dict[str, Any]:
    try:
        return json.loads(path.read_text(encoding='utf-8'))
    except Exception:
        return dict(default)


def _save_json(path: Path, data: Dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2), encoding='utf-8')


def _config() -> Dict[str, Any]:
    cfg = _load_json(CONFIG_PATH, {})
    return cfg.get('nan0_model_router') or {
        'enabled': True,
        'ollama_url': 'http://localhost:11434/api/generate',
        'live_model': 'tinyllama:latest',
        'social_model': 'qwen2.5:3b',
        'deep_model': 'qwen2.5:7b',
        'deep_enabled': False,
        'live_timeout': 7,
        'social_timeout': 18,
        'deep_timeout': 45,
        'use_llm_for_live': False,
        'use_llm_for_social': True,
        'temperature': 0.8,
    }


def clean_nan0_line(line: str) -> str:
    text = (line or '').strip().strip('"').strip("'")
    if not text:
        return ''
    low = text.lower()
    if any(bad in low for bad in BANNED_SPEECH_FRAGMENTS):
        return ''
    # Kill accidental JSON/object leakage.
    if text.startswith('{') or text.startswith('[') or 'thought_text' in low or 'thought_packet' in low:
        return ''
    # Kill assistant phrasing.
    if low.startswith(('sure,', 'of course', 'as an ai', 'i can help', 'here is', 'here are')):
        return ''
    # Keep it short enough for live Nan0.
    if len(text) > 180:
        text = text[:177].rstrip() + '...'
    return text


def classify_event(event: Dict[str, Any]) -> Tuple[str, str]:
    source = str(event.get('source') or '').lower()
    text = str(event.get('text') or event.get('message') or '').lower()
    seed = str(event.get('thought_seed') or '').lower()

    if source in {'discord', 'kyo', 'mic', 'voice'} or 'discord' in source:
        return 'social', 'social'
    if 'kyo' in text or 'nan0' in text or event.get('speaker'):
        return 'social', 'social'
    if seed in {'combat_spike', 'dark_drop', 'menu_open', 'text_heavy', 'motion_after_stable', 'stable_after_motion'}:
        return 'live', seed
    if event.get('combat'):
        return 'live', 'combat_spike'
    if event.get('menu_open'):
        return 'live', 'menu_open'
    if float(event.get('text_density') or 0.0) >= 0.35:
        return 'live', 'text_heavy'
    if event.get('dark_scene') or event.get('screen_state') == 'very_dark':
        return 'live', 'dark_drop'
    if event.get('screen_state') in {'motion', 'major_change'}:
        return 'live', 'motion_after_stable'
    return 'live', 'unknown'


def ollama_generate(model: str, prompt: str, timeout: float, temperature: float = 0.8) -> Optional[str]:
    cfg = _config()
    url = cfg.get('ollama_url') or 'http://localhost:11434/api/generate'
    if requests is None:
        return None
    payload = {
        'model': model,
        'prompt': prompt,
        'stream': False,
        'options': {
            'temperature': temperature,
            'num_predict': 48,
        },
    }
    try:
        r = requests.post(url, json=payload, timeout=timeout)
        r.raise_for_status()
        data = r.json()
        return clean_nan0_line(data.get('response') or '')
    except Exception:
        return None


def _fallback(seed: str, recent: list[str]) -> str:
    pool = LIVE_FALLBACKS.get(seed) or LIVE_FALLBACKS['unknown']
    choices = [x for x in pool if x not in recent]
    if not choices:
        choices = pool
    return random.choice(choices)


def route_thought(event: Dict[str, Any]) -> Dict[str, Any]:
    cfg = _config()
    state = _load_json(STATE_PATH, {'recent_lines': [], 'last_route': '', 'last_seed': '', 'last_at': 0})
    route, seed = classify_event(event)
    recent = list(state.get('recent_lines') or [])[:12]

    line = ''
    model = ''
    used_llm = False

    if route == 'social':
        model = cfg.get('social_model') or 'qwen2.5:3b'
        prompt = f"{ROUTE_PROMPTS['social']}\n\nEvent:\n{json.dumps(event, ensure_ascii=True)[:1400]}\n\nNan0 line:"
        if cfg.get('use_llm_for_social', True):
            line = ollama_generate(model, prompt, float(cfg.get('social_timeout', 18)), float(cfg.get('temperature', 0.8))) or ''
            used_llm = bool(line)
        if not line:
            line = _fallback(seed, recent)
    elif route == 'deep':
        model = cfg.get('deep_model') or 'qwen2.5:7b'
        if cfg.get('deep_enabled', False):
            prompt = f"{ROUTE_PROMPTS['deep']}\n\nEvent:\n{json.dumps(event, ensure_ascii=True)[:2200]}"
            line = ollama_generate(model, prompt, float(cfg.get('deep_timeout', 45)), 0.5) or ''
            used_llm = bool(line)
    else:
        model = cfg.get('live_model') or 'tinyllama:latest'
        if cfg.get('use_llm_for_live', False):
            prompt = f"{ROUTE_PROMPTS['live']}\n\nEvent:\n{json.dumps(event, ensure_ascii=True)[:1000]}\n\nNan0 line:"
            line = ollama_generate(model, prompt, float(cfg.get('live_timeout', 7)), float(cfg.get('temperature', 0.8))) or ''
            used_llm = bool(line)
        if not line:
            line = _fallback(seed, recent)

    line = clean_nan0_line(line) or _fallback(seed, recent)
    recent = [line] + [x for x in recent if x != line]
    state.update({
        'recent_lines': recent[:12],
        'last_route': route,
        'last_seed': seed,
        'last_model': model,
        'last_used_llm': used_llm,
        'last_line': line,
        'last_at': time.time(),
    })
    _save_json(STATE_PATH, state)
    return {'route': route, 'seed': seed, 'model': model, 'used_llm': used_llm, 'line': line}


def thought_packet_to_event(packet: Dict[str, Any], vision_state: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    event: Dict[str, Any] = {}
    if vision_state:
        event.update(vision_state)
    if packet:
        event.update(packet)
        event['text'] = packet.get('thought_text') or event.get('text') or ''
        event['source'] = packet.get('source') or event.get('source') or 'vision'
    return event


def route_vision_state_file() -> Dict[str, Any]:
    vision = _load_json(VISION_STATE_PATH, {})
    packet = vision.get('thought_packet') or {}
    event = thought_packet_to_event(packet, vision)
    result = route_thought(event)
    vision['router'] = result
    if result.get('line'):
        vision['speech_allowed'] = True
        vision['routed_line'] = result['line']
        if isinstance(vision.get('thought_packet'), dict):
            vision['thought_packet']['thought_text'] = result['line']
    _save_json(VISION_STATE_PATH, vision)
    return result
