import asyncio
import json
import time
from pathlib import Path
from typing import Optional, Dict, Any

import mss
from PIL import Image, ImageChops, ImageStat

from src.modules.skills.base_skill import BaseSkill
from src.utils.logger import get_logger

logger = get_logger("bea.skills.nan0vision")


class Nan0VisionSkill(BaseSkill):
    """
    Nan0 V7 Fast Eyes Survival Vision.

    What this is:
      - monitor 3 only
      - fast visual state detection only
      - no Moondream
      - no second Ollama server
      - no HTTP calls from vision

    This keeps Nan0 sighted without letting vision kill the live brain.
    """

    def __init__(self, name, config, brain):
        super().__init__(name, config, brain)
        cfg = self.skill_config

        self.monitor_index = int(cfg.get("monitor", cfg.get("monitor_index", 3)))
        self.fast_interval = float(cfg.get("fast_interval", cfg.get("capture_interval", 2.0)))
        self.fast_width = int(cfg.get("fast_width", 320))
        self.fast_height = int(cfg.get("fast_height", 180))
        self.motion_threshold = float(cfg.get("motion_threshold", cfg.get("change_threshold", 10.0)))
        self.major_change_threshold = float(cfg.get("major_change_threshold", 22.0))
        self.dark_threshold = float(cfg.get("dark_threshold", 12.0))
        self.bright_threshold = float(cfg.get("bright_threshold", 225.0))
        self.fast_log_interval = float(cfg.get("fast_log_interval", 8.0))
        self.output_path = Path(cfg.get("output_path", "data/vision/nan0_latest_vision.json"))
        self.output_path.parent.mkdir(parents=True, exist_ok=True)

        self.running = False
        self.task = None
        self.previous_fast_frame: Optional[Image.Image] = None
        self.previous_brightness: Optional[float] = None
        self.previous_screen_state: Optional[str] = None
        self.latest_fast_state: Dict[str, Any] = {}
        self.last_fast_log_at = 0.0
        self.last_capture_error_at = 0.0

    def initialize(self):
        try:
            self._log_monitors()
            if self.monitor_index == 0:
                logger.warning("Nan0VisionSkill: monitor 0 is full desktop. Forcing monitor 3.")
                self.monitor_index = 3
            logger.info(f"Nan0VisionSkill: FAST EYES ONLY on monitor {self.monitor_index}")
            logger.info(
                "Nan0VisionSkill: no deep vision, no Moondream, no second Ollama lane. fast_interval=%.2fs"
                % self.fast_interval
            )
        except Exception as e:
            logger.error(f"Nan0VisionSkill: monitor initialization failed: {e}")

    async def start(self):
        if self.running:
            return
        self.running = True
        self.task = asyncio.create_task(self._vision_loop())
        logger.info("Nan0VisionSkill started.")

    async def stop(self):
        self.running = False
        if self.task:
            self.task.cancel()
            try:
                await self.task
            except asyncio.CancelledError:
                pass
        logger.info("Nan0VisionSkill stopped.")

    async def update(self):
        return

    def _log_monitors(self):
        with mss.mss() as sct:
            logger.info("Nan0VisionSkill: detected monitors from mss:")
            for i, monitor in enumerate(sct.monitors):
                logger.info(f"Monitor {i}: {monitor}")

    async def _vision_loop(self):
        while self.running:
            start = time.time()
            try:
                frame = self._capture_monitor()
                if frame is not None:
                    fast_state = self._analyze_fast(frame)
                    self.latest_fast_state = fast_state
                    self._write_latest_state()
                    self._log_fast_if_needed(fast_state)
            except Exception as e:
                logger.error(f"Nan0VisionSkill loop error: {e}")

            elapsed = time.time() - start
            await asyncio.sleep(max(0.05, self.fast_interval - elapsed))

    def _capture_monitor(self) -> Optional[Image.Image]:
        try:
            with mss.mss() as sct:
                monitors = sct.monitors
                if self.monitor_index >= len(monitors):
                    now = time.time()
                    if now - self.last_capture_error_at > 10:
                        logger.error(
                            f"Nan0VisionSkill: monitor {self.monitor_index} does not exist. Available: 0-{len(monitors)-1}"
                        )
                        self.last_capture_error_at = now
                    return None
                screenshot = sct.grab(monitors[self.monitor_index])
                return Image.frombytes("RGB", screenshot.size, screenshot.rgb)
        except Exception as e:
            logger.error(f"Nan0VisionSkill capture error: {e}")
            return None

    def _analyze_fast(self, image: Image.Image) -> Dict[str, Any]:
        small = image.copy()
        small.thumbnail((self.fast_width, self.fast_height))
        gray = small.convert("L")

        stat = ImageStat.Stat(gray)
        brightness = float(stat.mean[0]) if stat.mean else 0.0

        frame_diff = 0.0
        if self.previous_fast_frame is not None:
            diff = ImageChops.difference(gray, self.previous_fast_frame)
            diff_stat = ImageStat.Stat(diff)
            frame_diff = float(diff_stat.mean[0]) if diff_stat.mean else 0.0

        brightness_delta = 0.0
        if self.previous_brightness is not None:
            brightness_delta = abs(brightness - self.previous_brightness)

        moving = frame_diff >= self.motion_threshold
        major_change = frame_diff >= self.major_change_threshold

        if brightness < self.dark_threshold:
            screen_state = "very_dark"
        elif brightness > self.bright_threshold:
            screen_state = "very_bright"
        elif major_change:
            screen_state = "major_change"
        elif moving:
            screen_state = "motion"
        else:
            screen_state = "stable"

        state_changed = self.previous_screen_state is not None and screen_state != self.previous_screen_state

        self.previous_fast_frame = gray
        self.previous_brightness = brightness
        self.previous_screen_state = screen_state

        return {
            "timestamp": time.time(),
            "monitor": self.monitor_index,
            "screen_state": screen_state,
            "frame_diff": round(frame_diff, 3),
            "brightness": round(brightness, 3),
            "brightness_delta": round(brightness_delta, 3),
            "moving": bool(moving),
            "major_change": bool(major_change),
            "state_changed": bool(state_changed),
            "fast_interval": self.fast_interval,
            "deep_enabled": False,
            "summary": self._human_summary(screen_state, frame_diff, brightness, brightness_delta),
        }

    def _human_summary(self, state: str, diff: float, brightness: float, delta: float) -> str:
        if state == "very_dark":
            return "the screen is very dark"
        if state == "very_bright":
            return "the screen is very bright"
        if state == "major_change":
            return "the screen changed a lot"
        if state == "motion":
            return "there is motion on the screen"
        return "the screen is mostly stable"

    def _log_fast_if_needed(self, fast_state: Dict[str, Any]):
        now = time.time()
        if now - self.last_fast_log_at < self.fast_log_interval:
            return
        state = fast_state.get("screen_state", "unknown")
        if state != "stable":
            logger.info(
                "Fast Eyes: %s diff=%.2f brightness=%.1f delta=%.1f"
                % (
                    state,
                    fast_state.get("frame_diff", 0.0),
                    fast_state.get("brightness", 0.0),
                    fast_state.get("brightness_delta", 0.0),
                )
            )
            self.last_fast_log_at = now

    def _write_latest_state(self):
        payload = {
            "timestamp": time.time(),
            "fast": self.latest_fast_state,
            "deep_summary": "",
            "deep_reason": "disabled_survival_mode",
            "deep_age_seconds": None,
            "deep_busy": False,
            "deep_enabled": False,
            "monitor": self.monitor_index,
        }
        try:
            self.output_path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
        except Exception as e:
            logger.error(f"Nan0VisionSkill: failed to write latest state: {e}")

    async def get_latest_analysis(self) -> Optional[str]:
        fast = self.latest_fast_state or {}
        if not fast:
            return None
        summary = fast.get("summary") or fast.get("screen_state")
        return (
            f"fast eyes on monitor {fast.get('monitor', self.monitor_index)}: {summary}; "
            f"brightness {fast.get('brightness')}; motion diff {fast.get('frame_diff')}"
        )
